set(_winglib2_prefix "${CMAKE_CURRENT_LIST_DIR}/@WL2_INSTALLED_UNINSTALL_PREFIX_RELATIVE@")
get_filename_component(_winglib2_prefix "${_winglib2_prefix}" ABSOLUTE)
set(_winglib2_manifest "${CMAKE_CURRENT_LIST_DIR}/winglib2InstalledManifest.txt")

if(NOT EXISTS "${_winglib2_manifest}")
    message(FATAL_ERROR "Cannot find Winglib2 install manifest: ${_winglib2_manifest}")
endif()

file(READ "${_winglib2_manifest}" _manifest)
string(REGEX REPLACE "\n$" "" _manifest "${_manifest}")
string(REPLACE "\n" ";" _entries "${_manifest}")

foreach(_entry IN LISTS _entries)
    if(_entry STREQUAL "")
        continue()
    endif()

    if(_entry MATCHES "[*?]")
        file(GLOB _matches "${_winglib2_prefix}/${_entry}")
    else()
        set(_matches "${_winglib2_prefix}/${_entry}")
    endif()

    foreach(_file IN LISTS _matches)
        if(EXISTS "${_file}" OR IS_SYMLINK "${_file}")
            message(STATUS "Removing ${_file}")
            file(REMOVE "${_file}")
        else()
            message(STATUS "Already removed: ${_file}")
        endif()
    endforeach()
endforeach()

function(_winglib2_remove_empty_dir relative_dir)
    set(_dir "${_winglib2_prefix}/${relative_dir}")
    if(IS_DIRECTORY "${_dir}")
        file(GLOB _children "${_dir}/*")
        if(NOT _children)
            message(STATUS "Removing empty directory ${_dir}")
            file(REMOVE_RECURSE "${_dir}")
        endif()
    endif()
endfunction()

_winglib2_remove_empty_dir("@CMAKE_INSTALL_INCLUDEDIR@/wl2")
_winglib2_remove_empty_dir("@CMAKE_INSTALL_INCLUDEDIR@/winglib2")
_winglib2_remove_empty_dir("@CMAKE_INSTALL_INCLUDEDIR@/wl2_curl")
_winglib2_remove_empty_dir("@CMAKE_INSTALL_INCLUDEDIR@/wl2_membus")
_winglib2_remove_empty_dir("@CMAKE_INSTALL_INCLUDEDIR@/curl")
_winglib2_remove_empty_dir("@CMAKE_INSTALL_INCLUDEDIR@/quickjs")
_winglib2_remove_empty_dir("@CMAKE_INSTALL_LIBDIR@/cmake/winglib2/deps")
_winglib2_remove_empty_dir("@CMAKE_INSTALL_LIBDIR@/cmake/winglib2")
_winglib2_remove_empty_dir("@CMAKE_INSTALL_LIBDIR@/cmake")
