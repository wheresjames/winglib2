PROJECT_NAME           = "@PROJECT_NAME@"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
PROJECT_BRIEF          = "@PROJECT_DESCRIPTION@"

OUTPUT_DIRECTORY       = "@CMAKE_CURRENT_BINARY_DIR@/docs/doxygen"
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English

INPUT                  = "@CMAKE_CURRENT_SOURCE_DIR@/include" \
                         "@CMAKE_CURRENT_SOURCE_DIR@/modules" \
                         "@CMAKE_CURRENT_SOURCE_DIR@/docs"
USE_MDFILE_AS_MAINPAGE = "@CMAKE_CURRENT_SOURCE_DIR@/docs/mainpage.md"
FILE_PATTERNS          = *.h *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/* */.deps/*

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO
MARKDOWN_SUPPORT       = YES
# Use GitHub-style header anchors so intra-doc links like [Text](#some-heading)
# resolve the same way they do when the Markdown is rendered on GitHub.
MARKDOWN_ID_STYLE      = GITHUB
AUTOLINK_SUPPORT       = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO

GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = NO

FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = "@CMAKE_CURRENT_SOURCE_DIR@"

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
EXPAND_ONLY_PREDEF     = NO

HAVE_DOT               = NO
